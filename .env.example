# LetLoyal — Environment Variables
# Copy this file to .env and fill in your values

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://letloyal:STRONG_PASSWORD_HERE@localhost:5432/letloyal

# JWT signing secret — generate with: openssl rand -hex 64
JWT_SECRET=replace_with_64_char_hex_secret

# Your domain (no trailing slash)
NEXT_PUBLIC_BASE_URL=https://yourdomain.com

# Node environment
NODE_ENV=production

# Server port (hPanel uses the PORT env var automatically)
PORT=3000

# HMAC secret for spend-based QR codes — generate with: openssl rand -hex 32
QR_HMAC_SECRET=replace_with_32_char_hex_secret
